# 使用 OpenJDK 11 slim 版本作为基础镜像
FROM openjdk:11-jdk-slim

# 设置工作目录
WORKDIR /app

# 安装 Maven
RUN apt-get update && \
    apt-get install -y maven && \
    rm -rf /var/lib/apt/lists/*

# 复制项目依赖文件
COPY pom.xml .
COPY .mvn .mvn
COPY mvnw .

# 下载 Maven 依赖
RUN ./mvnw dependency:go-offline

# 复制源代码
COPY src src

# 暴露端口
EXPOSE 8080

# 开发模式下的启动命令
CMD ["./mvnw", "spring-boot:run", "-Dspring-boot.run.profiles=dev"]